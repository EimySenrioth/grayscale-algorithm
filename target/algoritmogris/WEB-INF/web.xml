<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Scharr Edge Detection</display-name>


    <!--
        NOTA: EdgeDetectionServlet NO se declara aquí porque ya usa
        la anotación @WebServlet("/api/process") en su clase Java.
        Declararlo aquí también causaría un conflicto de mapeo duplicado.
    -->


    <!-- Configuración de CORS para que el frontend React pueda comunicarse -->
    <filter>
        <filter-name>CORSFilter</filter-name>
        <filter-class>com.algoritmogris.servlet.CORSFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>CORSFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

</web-app>
